<launch>
    <arg name="robot" default="march6" doc="Robot to use."/>

    <param name="robot_description" textfile="$(find march_description)/urdf/$(arg robot).urdf"/>

    <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" launch-prefix="valgrind --tool=callgrind --callgrind-out-file='callgrind.robot_state_publisher.%p'"/>

    <rosparam file="$(find march_rqt_gait_generator)/config/layout.yaml" command="load"/>

    <node name="march_rqt_gait_generator" pkg="march_rqt_gait_generator" type="march_rqt_gait_generator" output="screen" required="true" launch-prefix="valgrind --tool=callgrind --callgrind-out-file='callgrind.march_rqt_gait_generator.%p'"/>
</launch>
